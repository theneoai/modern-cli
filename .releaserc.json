{
  "branches": [
    "main",
    { "name": "develop", "prerelease": "beta" },
    { "name": "alpha",   "prerelease": "alpha" }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat",     "release": "minor" },
          { "type": "fix",      "release": "patch" },
          { "type": "perf",     "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs",     "release": false   },
          { "type": "style",    "release": false   },
          { "type": "test",     "release": false   },
          { "type": "chore",    "release": false   },
          { "type": "ci",       "release": false   },
          { "breaking": true,   "release": "major" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat",     "section": "✨ Features"     },
            { "type": "fix",      "section": "🐛 Bug Fixes"    },
            { "type": "perf",     "section": "⚡ Performance"  },
            { "type": "refactor", "section": "♻️  Refactoring" },
            { "type": "docs",     "section": "📖 Documentation", "hidden": false },
            { "type": "test",     "section": "🧪 Tests",         "hidden": true  },
            { "type": "chore",    "section": "🔧 Chores",        "hidden": true  },
            { "type": "ci",       "section": "👷 CI",            "hidden": true  }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this project will be documented in this file."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "npm run build && node scripts/package-binaries.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "release-assets/modern-ai-cli-linux-x64.tar.gz",         "label": "Linux x64 binary (.tar.gz)" },
          { "path": "release-assets/modern-ai-cli-linux-x64.tar.gz.sha256",   "label": "Linux x64 SHA256" },
          { "path": "release-assets/modern-ai-cli-linux-arm64.tar.gz",        "label": "Linux arm64 binary (.tar.gz)" },
          { "path": "release-assets/modern-ai-cli-linux-arm64.tar.gz.sha256", "label": "Linux arm64 SHA256" },
          { "path": "release-assets/modern-ai-cli-macos-x64.tar.gz",          "label": "macOS x64 binary (.tar.gz)" },
          { "path": "release-assets/modern-ai-cli-macos-x64.tar.gz.sha256",   "label": "macOS x64 SHA256" },
          { "path": "release-assets/modern-ai-cli-macos-arm64.tar.gz",        "label": "macOS arm64 (Apple Silicon) (.tar.gz)" },
          { "path": "release-assets/modern-ai-cli-macos-arm64.tar.gz.sha256", "label": "macOS arm64 SHA256" },
          { "path": "release-assets/modern-ai-cli-win-x64.exe.zip",           "label": "Windows x64 binary (.zip)" },
          { "path": "release-assets/modern-ai-cli-win-x64.exe.zip.sha256",    "label": "Windows x64 SHA256" }
        ],
        "successComment": "🎉 This issue/PR is included in version ${nextRelease.version}! Install via:\n```bash\nnpm install -g modern-ai-cli@${nextRelease.version}\n```",
        "releasedLabels": ["released"],
        "addReleases": "bottom"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "package-lock.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
