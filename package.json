{
  "name": "modern-ai-cli",
  "version": "0.1.0",
  "description": "A modern AI-powered CLI scaffold built with TypeScript, Commander.js, and Claude API",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ai": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/embed-version.mjs",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts' --ignore-pattern 'src/__tests__/**'",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "release": "semantic-release",
    "prepare": "husky",
    "pkg:linux-x64": "pkg dist/index.js --target node20-linux-x64   --output release-assets/modern-ai-cli-linux-x64",
    "pkg:linux-arm64": "pkg dist/index.js --target node20-linux-arm64  --output release-assets/modern-ai-cli-linux-arm64",
    "pkg:macos-x64": "pkg dist/index.js --target node20-macos-x64   --output release-assets/modern-ai-cli-macos-x64",
    "pkg:macos-arm64": "pkg dist/index.js --target node20-macos-arm64  --output release-assets/modern-ai-cli-macos-arm64",
    "pkg:win-x64": "pkg dist/index.js --target node20-win-x64      --output release-assets/modern-ai-cli-win-x64.exe",
    "pkg:all": "npm run build && npm run pkg:linux-x64 && npm run pkg:linux-arm64 && npm run pkg:macos-x64 && npm run pkg:macos-arm64 && npm run pkg:win-x64"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "release-assets"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.0.0",
    "figures": "^6.1.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@yao-pkg/pkg": "^6.14.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.2.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "claude",
    "anthropic",
    "scaffold",
    "typescript",
    "modern-cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
