{
  "name": "hyperterminal",
  "version": "0.2.0",
  "description": "面向未来的超级终端 - AI 原生的个人操作系统",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hyper": "./dist/index.js",
    "ht": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "docs/"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/embed-version.mjs",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts' --ignore-pattern 'src/__tests__/**'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "semantic-release",
    "prepare": "husky",
    "pkg:linux-x64": "pkg dist/index.js --target node20-linux-x64   --output release-assets/hyper-linux-x64",
    "pkg:linux-arm64": "pkg dist/index.js --target node20-linux-arm64  --output release-assets/hyper-linux-arm64",
    "pkg:macos-x64": "pkg dist/index.js --target node20-macos-x64   --output release-assets/hyper-macos-x64",
    "pkg:macos-arm64": "pkg dist/index.js --target node20-macos-arm64  --output release-assets/hyper-macos-arm64",
    "pkg:win-x64": "pkg dist/index.js --target node20-win-x64      --output release-assets/hyper-win-x64.exe",
    "pkg:all": "npm run build && npm run pkg:linux-x64 && npm run pkg:linux-arm64 && npm run pkg:macos-x64 && npm run pkg:macos-arm64 && npm run pkg:win-x64",
    "auto-dev": "node scripts/auto-dev.js",
    "workbench": "node dist/index.js tui",
    "features:update": "node scripts/update-features.js"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "release-assets"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@clack/prompts": "^0.9.1",
    "better-sqlite3": "^12.1.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "cli-spinners": "^3.4.0",
    "commander": "^13.1.0",
    "conf": "^13.0.0",
    "dayjs": "^1.11.13",
    "eventemitter3": "^5.0.1",
    "fast-glob": "^3.3.3",
    "figlet": "^1.11.0",
    "figures": "^6.1.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "semver": "^7.7.2",
    "strip-ansi": "^7.1.0",
    "uuid": "^11.1.0",
    "wrap-ansi": "^9.0.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.73"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.28",
    "@types/semver": "^7.7.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.1.3",
    "@yao-pkg/pkg": "^6.14.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "terminal",
    "automation",
    "workflow",
    "mcp",
    "hyperterminal",
    "personal-os"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
